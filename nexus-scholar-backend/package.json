    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport": "^1.0.0",
    "@types/nodemailer": "^6.4.0",
    "eslint": "^8.0.0",
    "@nestjs/schematics": "^10.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/express": "^4.17.0",
    "tsconfig-paths": "^4.2.0"
