    "playwright": "^1.45.0",
    "ioredis": "^5.3.0",
    "zod": "^3.22.0",
    "@nestjs/passport": "^10.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "@nestjs/bullmq": "^10.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
